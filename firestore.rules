rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidRegistration(data) {
      return data.keys().hasAll(['totalAmount', 'status', 'createdAt', 'updatedAt']) &&
             data.totalAmount is number &&
             data.status in ['pending', 'completed'] &&
             data.get('signatureData', '') is string &&
             data.get('signatureData', '').size() <= 100000;
    }

    function isValidTraveler(data, registrationId) {
      return data.keys().hasAll(['registrationId', 'name', 'passport', 'passportExpiry', 'dob', 'addressLine1', 'city', 'state', 'country', 'role', 'createdAt', 'updatedAt']) &&
             data.registrationId == registrationId &&
             data.name is string && data.name.size() <= 100 &&
             data.passport is string && data.passport.size() <= 100 &&
             data.passportExpiry is string && data.passportExpiry.size() <= 50 &&
             data.dob is string && data.dob.size() <= 50 &&
             data.addressLine1 is string && data.addressLine1.size() <= 200 &&
             data.city is string && data.city.size() <= 100 &&
             data.state is string && data.state.size() <= 100 &&
             data.country is string && data.country.size() <= 100 &&
             data.role is string && data.role.size() <= 100;
    }

    match /registrations/{registrationId} {
      allow get: if isValidId(registrationId);
      allow list: if false; // No public listing
      
      allow create: if
                    isValidId(registrationId) && 
                    isValidRegistration(incoming()) && 
                    incoming().keys().size() <= 5 &&
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time;
                    
      allow update: if
                    isValidId(registrationId) && 
                    isValidRegistration(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalAmount', 'signatureData', 'updatedAt']);
                    
      match /travelers/{travelerId} {
        allow get: if isValidId(registrationId) && isValidId(travelerId);
        allow list: if isValidId(registrationId);
        
        allow create: if
                      isValidId(registrationId) && isValidId(travelerId) && 
                      isValidTraveler(incoming(), registrationId) && 
                      incoming().keys().size() == 12 &&
                      incoming().createdAt == request.time && 
                      incoming().updatedAt == request.time &&
                      existsAfter(/databases/$(database)/documents/registrations/$(registrationId));
                      
        allow update: if
                      isValidId(registrationId) && isValidId(travelerId) && 
                      isValidTraveler(incoming(), registrationId) && 
                      incoming().registrationId == existing().registrationId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'passport', 'passportExpiry', 'dob', 'addressLine1', 'city', 'state', 'country', 'role', 'updatedAt']);
                      
        allow delete: if isValidId(registrationId) && isValidId(travelerId);
      }
    }
  }
}
